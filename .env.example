# ============================================
# Lecture2Anki Configuration
# ============================================
# Copy this file to .env and customize for your setup:
#   cp .env.example .env
#
# All settings have sensible defaults — you only need to
# change what doesn't work for your machine.
# ============================================

# --------------------------------------------
# Ollama (Local LLM)
# --------------------------------------------
# Where Ollama is running (default works if installed locally)
OLLAMA_HOST=http://localhost:11434

# Which model to use for flashcard generation
# Recommended for 8GB RAM:  qwen3.5:4b
# Lighter fallback for 8GB RAM: phi4-mini-reasoning, phi3, qwen2:1.5b
# Recommended for 16GB RAM: llama3, mistral, phi3:medium
# Recommended for 32GB RAM: llama3:70b, mixtral
OLLAMA_MODEL=qwen3.5:4b

# Max tokens for LLM context (lower = less RAM, but shorter chunks)
# 4096 is a good quality/speed balance for an 8GB M1
OLLAMA_CONTEXT_SIZE=4096

# --------------------------------------------
# Whisper (Transcription)
# --------------------------------------------
# Model size: tiny, base, small, medium, large
# Recommended for 8GB RAM:  small or base
# Recommended for 16GB RAM: medium
# Recommended for 32GB RAM: large
WHISPER_MODEL=small

# Language code (leave empty for auto-detect)
# Examples: en, es, fr, de, zh, ja, ko, pt, ru, ar
WHISPER_LANGUAGE=en

# --------------------------------------------
# Recording
# --------------------------------------------
# How often to process audio chunks (seconds)
# Lower = more responsive but more CPU
CHUNK_INTERVAL_SECONDS=30

# --------------------------------------------
# Card Generation
# --------------------------------------------
# Target words per chunk sent to the LLM
# Slightly smaller chunks help 8GB machines stay more consistent
CHUNK_TARGET_WORDS=700

# Max words per chunk (hard limit)
# Keep this close to target for better prompt adherence
CHUNK_MAX_WORDS=900

# Min/max cards to generate per chunk (hints to LLM)
CARDS_MIN_PER_CHUNK=5
CARDS_MAX_PER_CHUNK=10

# --------------------------------------------
# Anki
# --------------------------------------------
# AnkiConnect URL (default works if Anki is running locally)
ANKI_CONNECT_URL=http://localhost:8765

# Root deck name (your course decks nest under this)
# Example: "Lectures" creates "Lectures::AI::Midterm 1"
# Leave empty to put course decks at root: "AI::Midterm 1"
ANKI_ROOT_DECK=Lectures

# Note type (must exist in your Anki — "Basic" is built-in)
ANKI_NOTE_TYPE=Basic

# --------------------------------------------
# Storage
# --------------------------------------------
# Database location
# Default: ~/.lecture2anki/lecture2anki.db
# DATABASE_PATH=~/.lecture2anki/lecture2anki.db

# Audio recordings backup (optional)
# Leave empty to not save recordings after transcription
# RECORDINGS_PATH=~/.lecture2anki/recordings

# --------------------------------------------
# Logging
# --------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
